# Dependencies
node_modules/

# Next.js build output
.next/
.next/cache/

# Static export / build folders
out/
build/
dist/

# Vercel
.vercel/
.now/

# Cloudflare Pages / Workers (Wrangler)
.wrangler/
workers-site/

# Wrangler / Cloudflare Pages local config and temporary files
# ignore local wrangler config files (do not commit account-specific configs)
wrangler.toml
wrangler.local.toml
wrangler.*.toml

# ignore wrangler temporary/state folders explicitly
.wrangler/tmp/
.wrangler/state/
.wrangler/**

# Environment variables (local overrides)
.env.local
.env.*.local
.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Coverage and reports
coverage/
coverage-*

# IDE / editor
.vscode/
.idea/
*.sublime-workspace

# Misc
*.pem
*.key


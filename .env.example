# ─────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────

# Google Gemini AI API Key
# Obtén tu clave en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Supabase
# Encuentra estos valores en: https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL pública del sitio (origen canónico, sin barra final). Obligatoria en producción
# (p. ej. Cloudflare Pages) para que el redirect post-login OAuth coincida con
# Authentication → URL Configuration → Redirect URLs en Supabase.
# En local déjala vacía: se usa http://localhost:<puerto> automáticamente.
# VITE_APP_URL=https://tu-dominio.com
